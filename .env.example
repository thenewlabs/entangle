# Copy to .env and adjust. Never commit a real .env — it is gitignored.
# Secrets (RELAY_AGENT_TOKEN, passwords) belong only in the local .env.

# Server configuration
PORT=8080
HOST=0.0.0.0
PUBLIC_ORIGIN=https://suncoder.dev

# Timeouts and limits
RELAY_IDLE_TIMEOUT_MS=120000
AGENT_HEARTBEAT_MS=15000
CMD_DEFAULT_WALL_MS=60000
TTY_IDLE_TIMEOUT_MS=1200000
MAX_OUT_BYTES=10485760
MAX_FRAME_BYTES=1048576

# Agent execution
AGENT_SHELL=/bin/bash
# Leave AGENT_DEFAULT_CWD and AGENT_ALLOWED_CWD unset to bind the agent to the
# directory it was launched in (default working dir AND execution boundary, so
# a run cannot escape it). Set them only to override that default.
# AGENT_DEFAULT_CWD=/srv/work
# AGENT_ALLOWED_CWD=/home:/Users:/srv
SPAWN_SANDBOX=none

# Validation limits
MAX_ARG_COUNT=256
MAX_ARG_LEN=16384

# Logging
LOG_LEVEL=info

# Optional: IP based coarse rate limits (relay only)
RELAY_RATE_RPS=10
RELAY_BURST=50

# Optional: shared secret required to register an agent. Set this in production
# so random clients cannot register and squat capabilities.
# RELAY_AGENT_TOKEN=

# Optional: routing map ceilings
# RELAY_MAX_AGENTS=10000
# RELAY_MAX_CAPS_PER_AGENT=256
