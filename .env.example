# Copy to .env and adjust. Never commit a real .env — it is gitignored.
# Secrets (RELAY_AGENT_TOKEN, passwords) belong only in the local .env.

# Server configuration
PORT=8080
HOST=0.0.0.0
PUBLIC_ORIGIN=https://suncoder.dev

# Timeouts and limits
RELAY_IDLE_TIMEOUT_MS=120000
AGENT_HEARTBEAT_MS=15000
CMD_DEFAULT_WALL_MS=60000
TTY_IDLE_TIMEOUT_MS=1200000
MAX_OUT_BYTES=10485760
MAX_FRAME_BYTES=1048576

# Agent execution
AGENT_SHELL=/bin/bash
# AGENT_DEFAULT_CWD is the single directory knob: runs start here AND are
# confined here. Leave it unset to automatically use the directory the
# entangle-agent process was launched in.
# AGENT_DEFAULT_CWD=/srv/work
#
# NOTE: this only constrains the INITIAL working directory. It is NOT a
# filesystem sandbox: a permitted command can still read/write absolute paths
# or `cd` elsewhere. For a real boundary run the agent inside a
# container/chroot/namespace or set SPAWN_SANDBOX to an OS sandbox.
SPAWN_SANDBOX=none

# Validation limits
MAX_ARG_COUNT=256
MAX_ARG_LEN=16384

# Logging
LOG_LEVEL=info

# Optional: IP based coarse rate limits (relay only)
RELAY_RATE_RPS=10
RELAY_BURST=50

# Shared secret required to register an agent. STRONGLY recommended in any
# non-local deployment — without it, arbitrary clients can register agents and
# squat capabilities.
# RELAY_AGENT_TOKEN=

# Fail closed: refuse agent registration unless RELAY_AGENT_TOKEN is set. This
# is ON automatically when NODE_ENV=production; set it explicitly to require a
# token in other environments too.
# RELAY_REQUIRE_AGENT_TOKEN=1

# Optional: routing map ceilings
# RELAY_MAX_AGENTS=10000
# RELAY_MAX_CAPS_PER_AGENT=256
