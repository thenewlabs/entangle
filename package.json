{
  "name": "@thenewlabs/entangle",
  "version": "2.0.1",
  "private": true,
  "description": "Secure blind relay for exposing CLI tools",
  "workspaces": [
    "packages/*",
    "agent",
    "server",
    "invoke",
    "web"
  ],
  "scripts": {
    "build": "npm run build --workspaces && node scripts/build-dist.js",
    "dev": "npm run dev --workspace=@thenewlabs/entangle-relay",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "clean": "npm run clean --workspaces --if-present"
  },
  "keywords": [
    "security",
    "relay",
    "cli",
    "remote"
  ],
  "author": "Sunpix",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "@vitest/coverage-v8": "^4.1.10",
    "esbuild": "^0.28.1",
    "typescript": "^5.9.3",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
