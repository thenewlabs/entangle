{
  "name": "@sunpix/entangle",
  "version": "1.0.0",
  "private": true,
  "description": "Secure blind relay for exposing CLI tools",
  "workspaces": [
    "packages/*",
    "agent",
    "server",
    "invoke",
    "web"
  ],
  "scripts": {
    "build": "npm run build --workspaces && node scripts/build-dist.js",
    "dev": "npm run dev --workspace=@sunpix/entangle-server",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "clean": "npm run clean --workspaces --if-present"
  },
  "keywords": [
    "security",
    "relay",
    "cli",
    "remote"
  ],
  "author": "Sunpix",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@vitest/coverage-v8": "^1.2.0",
    "esbuild": "^0.25.9",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  }
}
