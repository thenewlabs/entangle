{
  "name": "@sunpix/entangle",
  "version": "1.0.0",
  "private": true,
  "description": "Secure blind relay for exposing CLI tools",
  "workspaces": [
    "packages/*",
    "agent",
    "server",
    "invoke",
    "web"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "dev": "npm run dev --workspace=@sunpix/entangle-server",
    "test": "npm run test --workspaces --if-present",
    "clean": "npm run clean --workspaces --if-present"
  },
  "keywords": ["security", "relay", "cli", "remote"],
  "author": "Sunpix",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3"
  }
}
