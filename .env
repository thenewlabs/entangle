# Reverse proxy terminates TLS. Server listens HTTP on this port.
PORT=3005
HOST=0.0.0.0
PUBLIC_ORIGIN=https://labs-fwd-3005.a.spring.nl
# Agent relay URL (optional, defaults to PUBLIC_ORIGIN)
RELAY_URL=https://labs-fwd-3005.a.spring.nl

# Sizing and limits
MAX_FRAME_BYTES=1048576
RELAY_IDLE_TIMEOUT_MS=120000
AGENT_HEARTBEAT_MS=15000
MAX_CONCURRENT_RUNS_PER_CAP=1

# Logging
LOG_LEVEL=info

# SPA
SPA_BASE_PATH=/

# Optional: IP based coarse rate limits (relay only)
RELAY_RATE_RPS=10
RELAY_BURST=50

# Agent specific
AGENT_TOOL=/usr/bin/claude
AGENT_ALLOWED_CWD=/home:/srv/projects
MAX_ARG_COUNT=64
MAX_ARG_LEN=4096